{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "functions": {
    "app/api/admin/market/**/*.ts": {
      "maxDuration": 60
    },
    "app/api/admin/parlays/**/*.ts": {
      "maxDuration": 60
    },
    "app/api/admin/multisport/**/*.ts": {
      "maxDuration": 120
    },
    "app/api/admin/social/**/*.ts": {
      "maxDuration": 60
    },
    "app/api/social/images/**/*.tsx": {
      "maxDuration": 30
    },
    "app/api/admin/predictions/**/*.ts": {
      "maxDuration": 120
    },
    "app/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/admin/parlays/sync-backend-scheduled",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/admin/additional-markets/sync-scheduled",
      "schedule": "0 */3 * * *"
    },
    {
      "path": "/api/admin/parlays/generate-best-scheduled",
      "schedule": "30 */3 * * *"
    },
    {
      "path": "/api/admin/parlays/sync-scheduled",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/admin/market/sync-scheduled?type=live",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/admin/market/sync-scheduled?type=upcoming",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/admin/market/sync-scheduled?type=completed",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/admin/market/zombie-sweep",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/admin/predictions/sync-from-availability-scheduled",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/admin/template-blogs/scheduled",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/admin/social/twitter/scheduled",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/admin/social/twitter/post-scheduled",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/admin/settle-saved-bets",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/admin/clv/sync-scheduled",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/admin/social/results/scheduled",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/admin/social/summary/morning",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/admin/social/summary/evening",
      "schedule": "0 22 * * *"
    },
    {
      "path": "/api/admin/social/multisport/scheduled",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/admin/social/live-events",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/admin/multisport/sync",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/admin/predictions/refresh-progressive",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/admin/multisport/blogs",
      "schedule": "30 2 * * *"
    }
  ],
  "env": {
    "PRISMA_GENERATE_DATAPROXY": "true"
  }
} 